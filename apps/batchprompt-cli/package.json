{
  "name": "batchprompt-cli",
  "version": "0.1.0",
  "description": "CLI tool for BatchPrompt",
  "type": "module",
  "bin": {
    "batchprompt": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b --verbose",
    "watch": "tsc -b -w",
    "debug-init": "tsx src/index.ts init 'tell me at what ranking the website butlerapp is for the keyword kursverwaltung'",
    "debug-schema": "tsx src/index.ts schema",
    "debug-lead-find": "examples/02-lead-gen/01-find-leads/1-find.sh",
    "debug-create-images": "examples/01-rag-imagegen/run.sh",
    "debug-lead-enrich": "examples/02-lead-gen/02-enrich/2-enrich.sh /Users/tobiasanhalt/Development/batchprompt/apps/batchprompt-cli/out/02-lead-gen/Schwimmschule_enriched_small.csv /Users/tobiasanhalt/Development/batchprompt/apps/batchprompt-cli/out/02-lead-gen/Schwimmschule_enriched_small.csv",
    "debug-email": "examples/02-lead-gen/03-generate-email/4-email.sh out/02-lead-gen/Schwimmschule_enriched_small.csv",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "batchprompt": "workspace:*",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "eventemitter3": "^5.0.1",
    "handlebars": "^4.7.8",
    "json2csv": "6.0.0-alpha.2",
    "papaparse": "^5.4.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/json2csv": "^5.0.7",
    "@types/node": "^20.19.27",
    "@types/papaparse": "^5.3.14",
    "openai": "^6.15.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  }
}
