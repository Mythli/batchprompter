{
  "taskConcurrency": 1,
  "logLevel": "warn",
  "model": {
    "model": "google/gemini-3-flash-preview",
    "thinkingLevel": "high"
  },
  "output": {
    "tmpDir": "out/03-email-reply/.tmp"
  },
  "steps": [
    {
      "plugins": [
        {
          "type": "gmailReplier",
          "targetQuery": "is:unread",
          "limit": 200,
          "inspirationQuery": "subject:(re OR aw) from:me",
          "inspirationLimit": 10,
          "evaluateReply": true,
          "interactive": true,
          "draftModel": {
            "prompt": "You are a helpful assistant. Read the following email thread and draft a polite, professional reply in German. Keep it under 3 sentences."
          },
          "output": {
            "mode": "merge",
            "explode": true
          }
        }
      ]
    }
  ]
}
