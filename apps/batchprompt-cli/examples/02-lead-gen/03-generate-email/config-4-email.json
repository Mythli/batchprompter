{
  "model": {
    "model": "google/gemini-3-flash-preview",
    "thinkingLevel": "high"
  },
  "output": {
    "tmpDir": "out/02-lead-gen/emails/.tmp"
  },
  "dataOutputPath": "out/02-lead-gen/companies_emails.csv",
  "steps": [
    {
      "model": {
        "prompt": "examples/02-lead-gen/03-generate-email/prompt-subject.md"
      },
      "output": {
        "mode": "column",
        "column": "generatedSubject"
      }
    },
    {
      "model": {
        "prompt": "examples/02-lead-gen/03-generate-email/prompt-body.md"
      },
      "output": {
        "mode": "column",
        "column": "generatedEmail"
      }
    }
  ]
}
