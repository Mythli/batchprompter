{
  "output": {
    "tmpDir": "out/02-lead-gen/send/.tmp"
  },
  "dataOutputPath": "out/02-lead-gen/5-send-results.csv",
  "steps": [
    {
      "plugins": [
        {
          "type": "gmailSender",
          "to": "{{websiteAgent.decisionMaker.email}}",
          "subject": "Kontaktanfrage {{websiteAgent.companyName}}",
          "body": "{{generatedEmail}}",
          "delayMin": 0,
          "delayMax": 0,
          "sendIfReceived": true,
          "skipIfSubjectMatch": true,
          "replyToLastThread": false,
          "requireExistingThread": false,
          "output": {
            "mode": "merge"
          }
        }
      ]
    }
  ]
}
