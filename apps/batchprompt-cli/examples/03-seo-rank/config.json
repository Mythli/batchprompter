{
  "model": "google/gemini-3-flash-preview",
  "output": {
    "tmpDir": "out/03-seo-rank/.tmp"
  },
  "dataOutputPath": "out/03-seo-rank/results.csv",
  "inputLimit": 10,
  "steps": [
    {
      "plugins": [
        {
          "type": "web-search",
          "query": "{{keyword}}",
          "maxPages": 3,
          "limit": 30,
          "mode": "none",
          "gl": "de",
          "hl": "de",
          "selectModel": {
            "prompt": "Select up to 10 links that point to Butlerapp (butlerapp.de). If no Butlerapp link exists, select nothing."
          },
          "output": {
            "mode": "merge",
            "explode": true
          }
        }
      ]
    }
  ]
}
