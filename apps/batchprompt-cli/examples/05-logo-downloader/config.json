{
  "concurrency": 2,
  "output": {
    "tmpDir": "out/05-logo-downloader/.tmp"
  },
  "dataOutputPath": "out/05-logo-downloader/results.csv",
  "steps": [
    {
      "plugins": [
        {
          "type": "logoScraper",
          "url": "{{Website}}",
          "logoOutputPath": "out/05-logo-downloader/assets/{{ID}}_logo.png",
          "faviconOutputPath": "out/05-logo-downloader/assets/{{ID}}_favicon.png",
          "output": {
            "mode": "column",
            "column": "brand_assets"
          }
        }
      ],
      "model": {
        "prompt": "Describe the brand identity of {{Website}} based on the extracted logo and colors."
      },
      "output": {
        "mode": "column",
        "column": "brand_description"
      }
    }
  ]
}
