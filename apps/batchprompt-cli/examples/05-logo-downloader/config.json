{
  "_NOTE": "This example requires the logo-scraper plugin which is not yet available in the new architecture. It will fail at runtime.",
  "concurrency": 2,
  "output": {
    "tmpDir": "out/05-logo-downloader/.tmp"
  },
  "dataOutputPath": "out/05-logo-downloader/results.csv",
  "steps": [
    {
      "model": {
        "prompt": "Describe the brand identity of {{website_url}}."
      },
      "output": {
        "mode": "column",
        "column": "brand_description"
      }
    }
  ]
}
