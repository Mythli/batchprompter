#!/bin/bash
PATHS="packages/batchprompt/src packages/batchprompt/tests"
if [ -d "packages/batchprompt/test-helpers" ]; then
    PATHS="$PATHS packages/batchprompt/test-helpers"
fi

aider $(find $PATHS -type d \( -name "generated" -o -name "plugins" \) -prune -o -type f \( -name "*.ts" -o -name "*.js" \) ! -name "*.d.ts" -print) "$@"
