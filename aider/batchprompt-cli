#!/bin/bash
INCLUDE_LIB=false
args=()
for arg in "$@"; do
    if [ "$arg" == "--lib" ]; then
        INCLUDE_LIB=true
    else
        args+=("$arg")
    fi
done

PATHS="apps/batchprompt-cli/src"
if [ -d "apps/batchprompt-cli/tests" ]; then
    PATHS="$PATHS apps/batchprompt-cli/tests"
fi

if [ "$INCLUDE_LIB" = true ]; then
    PATHS="$PATHS packages/batchprompt/src packages/batchprompt/tests"
    if [ -d "packages/batchprompt/test-helpers" ]; then
        PATHS="$PATHS packages/batchprompt/test-helpers"
    fi
    aider $(find $PATHS -type d \( -name "generated" -o -name "plugins" \) -prune -o -type f \( -name "*.ts" -o -name "*.js" \) ! -name "*.d.ts" -print) "${args[@]}"
else
    aider $(find $PATHS -type f \( -name "*.ts" -o -name "*.js" \) ! -name "*.d.ts" -print) "${args[@]}"
fi
